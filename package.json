{
  "name": "viewerpdf",
  "widgetName": "ViewerPdf",
  "version": "1.0.0",
  "description": "A feature-rich, fully client-side PDF viewer for Mendix. Renders PDFs from base64, data URLs, or HTTP(S) URLs with thumbnails, full-text search, zoom, rotate, print, download, upload, copy-text, dark mode, and offline caching. Built on PDF.js, CSP-safe with zero external network requests.",
  "copyright": "© Mendix Technology BV 2026. All rights reserved.",
  "author": "Krishnaraj.R",
  "engines": {
    "node": ">=16"
  },
  "license": "Apache-2.0",
  "config": {
    "projectPath": "./tests/testProject",
    "mendixHost": "http://localhost:8080",
    "developmentPort": 3000
  },
  "packagePath": "mxtechies",
  "scripts": {
    "start": "pluggable-widgets-tools start:server",
    "dev": "pluggable-widgets-tools start:web",
    "prebuild": "node scripts/generate-pdfjs-ts.js",
    "build": "pluggable-widgets-tools build:web",
    "lint": "pluggable-widgets-tools lint",
    "lint:fix": "pluggable-widgets-tools lint:fix",
    "prerelease": "node scripts/generate-pdfjs-ts.js && npm run lint",
    "release": "pluggable-widgets-tools release:web"
  },
  "devDependencies": {
    "@mendix/pluggable-widgets-tools": "^11.6.0",
    "@types/big.js": "^6.0.2",
    "adm-zip": "^0.5.17"
  },
  "dependencies": {
    "classnames": "^2.2.6",
    "pdfjs-dist": "^3.11.174"
  },
  "resolutions": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
